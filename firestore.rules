rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // teens collection — allow create only
    match /teens/{teenId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;  // allow auth
    }
    // jobs collection — allow get (single doc read) only
    match /jobs/{jobId} {
      allow create: if true;
      allow get: if true;     // allow reading one document
      allow list: if request.auth != null;
      allow read, update, delete: if request.auth != null;
    }
    // everything else — deny all
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
